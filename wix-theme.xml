<?xml version="1.0" encoding="utf-8"?>
<Wix xmlns="http://schemas.microsoft.com/wix/2006/ui">
  
  <!-- Tabeza POS Theme Colors -->
  <WixVariable Id="WixUIBannerBmp" Value="banner-tabeza.bmp" />
  <WixVariable Id="WixUIDialogBmp" Value="dialog-tabeza.bmp" />
  
  <!-- Tabeza Brand Colors -->
  <WixVariable Id="WixUIOptionBmp" Value="option-tabeza.bmp" />
  <WixVariable Id="WixUIExclamationIco" Value="warning-tabeza.ico" />
  <WixVariable Id="WixUIInfoIco" Value="info-tabeza.ico" />
  
  <!-- Custom Theme Colors -->
  <TextStyle Id="WixUI_Font_Normal" Face="Segoe UI" Size="9" Red="51" Green="209" Blue="153" />
  <TextStyle Id="WixUI_Font_Bigger" Face="Segoe UI" Size="12" Red="51" Green="209" Blue="153" Bold="yes" />
  <TextStyle Id="WixUI_Font_Title" Face="Segoe UI" Size="15" Red="51" Green="209" Blue="153" Bold="yes" />
  
  <!-- Tabeza POS Color Scheme -->
  <!-- Primary: RGB(51, 209, 153) - Tabeza Green -->
  <!-- Secondary: RGB(0, 123, 255) - Tabeza Blue -->
  <!-- Accent: RGB(255, 171, 64) - Tabeza Orange -->
  
</Wix>
