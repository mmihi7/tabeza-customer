{
  "name": "tabeza",
  "version": "1.0.0",
  "private": true,
  "description": "Tabeza - Anonymous tab management system for bars and restaurants",
  "workspaces": [
    "apps/*",
    "packages/*",
    "api"
  ],
  "scripts": {
    "dev": "pnpm --parallel --filter \"./apps/*\" dev",
    "dev:customer": "pnpm --filter @tabeza/customer dev",
    "dev:staff": "pnpm --filter @tabeza/staff dev",
    "build": "pnpm --recursive --filter \"./packages/*\" --filter \"!@tabeza/code-guardrails\" --filter \"!@tabeza/escpos-parser\" --filter \"!@tabeza/validation\" build && pnpm --recursive --filter \"./apps/*\" build",
    "build:packages": "pnpm --recursive --filter \"./packages/*\" --filter \"!@tabeza/code-guardrails\" --filter \"!@tabeza/escpos-parser\" --filter \"!@tabeza/validation\" build",
    "build:customer": "pnpm --filter @tabeza/customer build",
    "build:staff": "pnpm --filter @tabeza/staff build",
    "build:printer-service": "pnpm --filter @tabeza/printer-service build-installer",
    "start": "pnpm --recursive --filter \"./apps/*\" start",
    "start:customer": "pnpm --filter @tabeza/customer start",
    "start:staff": "pnpm --filter @tabeza/staff start",
    "test": "pnpm --recursive --filter \"./packages/*\" test",
    "test:packages": "pnpm --recursive --filter \"./packages/*\" test",
    "lint": "pnpm --recursive lint",
    "clean": "pnpm --recursive clean && rimraf node_modules",
    "type-check": "pnpm --recursive type-check",
    "set-mode": "node dev-tools/scripts/set-venue-mode.js"
  },
  "devDependencies": {
    "@types/node": "^20.19.27",
    "@types/react": "^19.2.3"
  },
  "dependencies": {
    "@hcaptcha/react-hcaptcha": "^1.17.2",
    "@supabase/supabase-js": "^2.45.0",
    "@vercel/node": "^3.0.0",
    "lucide-react": "^0.468.0",
    "next": "^15.5.9",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "openai": "^4.104.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "packageManager": "pnpm@10.25.0+sha512.5e82639027af37cf832061bcc6d639c219634488e0f2baebe785028a793de7b525ffcd3f7ff574f5e9860654e098fe852ba8ac5dd5cefe1767d23a020a92f501"
}