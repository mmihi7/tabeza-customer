{
  "appId": "com.tabeza.connect",
  "productName": "TabezaConnect",
  "directories": {
    "output": "dist"
  },
  "files": [
    "src/**/*",
    "assets/**/*",
    "config.json",
    "package.json",
    "!src/**/*.test.js",
    "!src/**/__tests__/**"
  ],
  "asarUnpack": [
    "node_modules/winreg/**/*"
  ],
  "win": {
    "target": [
      {
        "target": "dir",
        "arch": ["x64"]
      }
    ],
    "requestedExecutionLevel": "asInvoker"
  },
  "publish": null
}
