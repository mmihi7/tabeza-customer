# Supabase Configuration (Required for production)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key
SUPABASE_SECRET_KEY=your-secret-key

# Customer App Origin
NEXT_PUBLIC_CUSTOMER_ORIGIN=https://your-domain.vercel.app

# hCaptcha (Required)
HCAPTCHA_SECRET_KEY=your-hcaptcha-secret-key
NEXT_PUBLIC_HCAPTCHA_SITE_KEY=your-hcaptcha-site-key

# M-Pesa Master Encryption Key (Required)
MPESA_KMS_KEY=your-mpesa-kms-key

# AI Receipt Parser - DeepSeek API (Optional)
DEEPSEEK_API_KEY=your-deepseek-api-key

# AI Receipt Parser - EC2 Instance (Optional)
EC2_PARSER_URL=http://your-ec2-instance:3100
