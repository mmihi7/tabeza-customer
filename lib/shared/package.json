{
  "name": "@tabeza/shared",
  "version": "1.0.0",
  "private": true,
  "description": "Shared types and utilities for Tabeza applications",
  "main": "index.ts",
  "types": "index.ts",
  "scripts": {
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:visual": "playwright test --config=playwright.config.ts",
    "test:visual:update": "playwright test --config=playwright.config.ts --update-snapshots",
    "test:visual:ui": "playwright test --config=playwright.config.ts --ui"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.89.0",
    "@tabeza/tax-rules": "workspace:*",
    "openai": "^4.77.3",
    "react": "^19.2.3",
    "react-dom": "^19.2.3"
  },
  "devDependencies": {
    "typescript": "^5.9.3",
    "jest": "^29.7.0",
    "@types/jest": "^29.5.14",
    "ts-jest": "^29.4.6",
    "fast-check": "^3.23.2",
    "@playwright/test": "^1.48.0"
  }
}